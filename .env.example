# FIH Emergence 环境变量配置

# ========== LLM Provider ==========
# 可选: openai, anthropic, moonshot, custom
LLM_PROVIDER=custom

# ========== Manager (决策/汇总) ==========
MANAGER_PROVIDER=custom
MANAGER_MODEL=glm-4-flash

# ========== Proposer (生成候选) ==========
PROPOSER_PROVIDER=custom
PROPOSER_MODEL=glm-4-flash

# ========== Worker (产出 Insight) ==========
# Worker_P (正方)
WORKER_PROVIDER=custom
WORKER_MODEL=glm-5.1

# ========== Auditor (审计/EI) ==========
AUDITOR_PROVIDER=custom
AUDITOR_MODEL=Qwen3-235B-A22B

# ========== Custom API (如果你使用自定义 API 兼容 OpenAI 格式) ==========
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.example.com/v1

# ========== Database ==========
FIH_DB_PATH=./data/fih_blackboard.db

# ========== API Server ==========
FIH_API_HOST=0.0.0.0
FIH_API_PORT=8000